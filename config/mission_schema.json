{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Drone Mission Schema",
  "description": "Schema for validated drone mission plans generated by the LLM planner",
  "type": "object",
  "required": ["mission_name", "vehicle_type", "actions"],
  "additionalProperties": false,
  "properties": {
    "mission_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable name for the mission"
    },
    "vehicle_type": {
      "type": "string",
      "enum": ["quadcopter"],
      "description": "Type of vehicle executing the mission"
    },
    "repeat_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 1,
      "description": "Number of times to repeat the action sequence (excluding takeoff/land)"
    },
    "actions": {
      "type": "array",
      "minItems": 2,
      "description": "Ordered list of actions for the drone to execute",
      "items": {
        "type": "object",
        "required": ["type", "params"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["takeoff", "goto", "loiter", "land", "return_to_launch"],
            "description": "Action type"
          },
          "params": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "altitude_m": {
                "type": "number",
                "minimum": 1,
                "maximum": 50,
                "description": "Target altitude in metres AGL"
              },
              "latitude_deg": {
                "type": "number",
                "minimum": -90,
                "maximum": 90,
                "description": "Target latitude in degrees"
              },
              "longitude_deg": {
                "type": "number",
                "minimum": -180,
                "maximum": 180,
                "description": "Target longitude in degrees"
              },
              "speed_mps": {
                "type": "number",
                "minimum": 0.5,
                "maximum": 15,
                "description": "Cruise speed in metres per second"
              },
              "duration_s": {
                "type": "number",
                "minimum": 1,
                "maximum": 60,
                "description": "Duration to hold position in seconds (for loiter)"
              },
              "heading_deg": {
                "type": "number",
                "minimum": 0,
                "maximum": 360,
                "description": "Heading in degrees (0=North, 90=East)"
              },
              "north_m": {
                "type": "number",
                "description": "North offset from home in metres (NED frame)"
              },
              "east_m": {
                "type": "number",
                "description": "East offset from home in metres (NED frame)"
              }
            }
          }
        }
      }
    },
    "safety_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_altitude_m": {
          "type": "number",
          "minimum": 5,
          "maximum": 50,
          "default": 30
        },
        "max_speed_mps": {
          "type": "number",
          "minimum": 1,
          "maximum": 15,
          "default": 10
        },
        "geofence_radius_m": {
          "type": "number",
          "minimum": 10,
          "maximum": 200,
          "default": 100
        }
      }
    }
  }
}
